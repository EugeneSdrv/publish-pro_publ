CI_REGISTRY_IMAGE=

# [service_settings]
PUB_API_HOST=0.0.0.0
PUB_API_PORT=8000
SECRET_KEY=!
# expiration time should be specified in minutes
ACCESS_TOKEN_EXPIRE=7
# expiration time should be specified in days
REFRESH_TOKEN_EXPIRE=15

# [admin_settings]
ADMIN_LOGIN=admin
ADMIN_PASSWORD=password

# [database_settings]
DB_HOST=pg
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=password

# [s3_storage_settings]
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9000
MINIO_ACCESS_KEY=USERNAME
MINIO_SECRET_KEY=password
MINIO_USE_SSL=False

# [redis_settings]
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=password

# [telegram_integration_settings]
BOT_TOKEN=
CHAT_ID=

# [frontend_settings] (used by docker-compose.prod.yml frontend service)
# Server-side fetches inside docker network
INTERNAL_API_BASE_URL=http://backend:8000
# Public origin used for canonical URLs and sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost
# Optional: set when frontend should call API on a different origin.
NEXT_PUBLIC_API_BASE_URL=
